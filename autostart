#!/bin/bash

# Seed MCP config on first run
mkdir -p "${HOME}/.config/Claude"
if [ ! -f "${HOME}/.config/Claude/claude_desktop_config.json" ]; then
    cp /defaults/claude_desktop_config.json "${HOME}/.config/Claude/claude_desktop_config.json"
fi

# Start gnome-keyring so Electron safeStorage can persist the OAuth token
eval $(echo "" | gnome-keyring-daemon --start --daemonize --components=secrets 2>/dev/null)
export GNOME_KEYRING_CONTROL

# Cowork socket daemon is now managed by s6 as /custom-services.d/cowork
# (it starts before this autostart runs and is supervised independently).

# If Claude Desktop is already running, don't spawn a duplicate (singleton lock
# would immediately kill it and trigger the watchdog restart loop). Just wait —
# the s6 watchdog only looks for THIS autostart script PID, so keeping it alive
# prevents the restart cycle.
if pgrep -f "electron.*app\.asar" > /dev/null; then
    sleep infinity
fi

# Fresh start: clean stale singleton locks from previous crashes
rm -f "${HOME}/.config/Claude/Singleton"*

# Run in foreground (no exec) so s6 watchdog can still see this script's PID.
claude-desktop --no-sandbox --disable-gpu --disable-gpu-compositing --disable-dev-shm-usage
